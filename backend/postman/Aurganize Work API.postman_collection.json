    {
      "name": "04 - Refresh",
      "item": [
        {
          "name": "04 — Refresh — happy path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"200 OK\", () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test(\"new access token\", () => pm.expect(data.access_token).to.be.a(\"string\"));",
                  "pm.test(\"new refresh token (rotated)\", () => {",
                  "  pm.expect(data.refresh_token).to.not.eql(pm.environment.get(\"refresh_token\"));",
                  "});",
                  "pm.environment.set(\"old_refresh_token\", pm.environment.get(\"refresh_token\"));",
                  "pm.environment.set(\"access_token\", data.access_token);",
                  "pm.environment.set(\"refresh_token\", data.refresh_token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\",\n  \"client\": \"web\"\n}",
