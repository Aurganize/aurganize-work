                  "",
                  "pm.test(\"has access_token\", ()=> pm.expect(data.access_token).to.be.a(\"string\"))",
                  "pm.test(\"hash refresh_token\", () => pm.expect(data.refresh_token).to.be.a(\"string\"))",
                  "",
                  "// Save for use in other requests",
                  "pm.environment.set(\"tenant_a_access_token\", data.access_token);",
                  "pm.environment.set(\"tenant_a_refresh_token\", data.refresh_token);",
                  "// Default access_token used by the collection-level bearer config",
                  "pm.environment.set(\"access_token\", data.access_token);",
                  "pm.environment.set(\"refresh_token\", data.refresh_token);"
