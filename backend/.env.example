# === Application ===
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# === Database ===
DATABASE_URL=postgres://aurganize:aurganize@localhost:5432/aurganize?sslmode=disable

# === JWT ===
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-me-with-a-real-secret-at-least-32-bytes-long-okay
JWT_ACCESS_TOKEN_TTL_WEB=8h
JWT_ACCESS_TOKEN_TTL_MOBILE=24h
REFRESH_TOKEN_TTL_WEB=168h
REFRESH_TOKEN_TTL_MOBILE=720h

# === CORS ===
# Comma-separated list of allowed origins for the Flutter web client
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Email (Resend) ===
# Get your API key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Aurganize Work

# === Blob storage (Cloudflare R2) ===
# Filled in Batch 4. Leave blank for Batch 1.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# === Logging ===
# debug | info | warn | error
LOG_LEVEL=debug
LOG_FORMAT=json   # json | text
